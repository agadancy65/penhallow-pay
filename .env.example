# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real credentials.

# ──────────────────────────────────────────────────────────────────────────
# VULNERABLE STATE (Week 1, before remediation)
# ──────────────────────────────────────────────────────────────────────────
# In the starting state, the app reads these directly. After your Key Vault
# migration (Week 1, Wed/Thu), the app should no longer need
# COGNITIVE_SERVICES_KEY here at all — it will pull the secret from Key
# Vault via Managed Identity instead.

COGNITIVE_SERVICES_ENDPOINT=https://your-cognitive-services-resource.cognitiveservices.azure.com/
COGNITIVE_SERVICES_KEY=your-test-key-here-never-commit-a-real-one

# ──────────────────────────────────────────────────────────────────────────
# POST-REMEDIATION STATE (after Week 1, Wed/Thu)
# ──────────────────────────────────────────────────────────────────────────
# Once the app is rewired to use Key Vault + Managed Identity, you only
# need this — no key in any environment variable at all.

# KEY_VAULT_URL=https://kv-penhallow-yourinitials.vault.azure.net
